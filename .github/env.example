# .env.example
# ─────────────────────────────────────────────────────────────
# Copy this file to .env and fill in your real values.
# NEVER commit .env to version control.
#
#   cp .env.example .env
# ─────────────────────────────────────────────────────────────

# URL of the Flask auth backend (default: local)
FLASK_API_URL=http://localhost:5000

# Serper API key for Google trending searches
# Get yours at https://serper.dev (free tier available)
SERPER_API_KEY=your_serper_api_key_here

# Secret key for Flask session signing
FLASK_SECRET_KEY=change_this_to_a_random_string

# JWT secret for token signing
JWT_SECRET_KEY=change_this_to_another_random_string
